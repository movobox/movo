{
  "name": "movo",
  "version": "0.1.0",
  "description": "Movo desktop AI studio for Pinoox.",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": {
  "name": "yoosef alipour",
  "email": "yoosefalipour@gmail.com"
   },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vue-tsc --noEmit && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "build:dir": "vue-tsc --noEmit && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "build:win": "vue-tsc --noEmit && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:win:vs": "cmd /d /s /c \"\\\"%ProgramFiles(x86)%\\Microsoft Visual Studio\\18\\BuildTools\\Common7\\Tools\\VsDevCmd.bat\\\" -arch=x64 -host_arch=x64 && npm run build:win\"",
    "build:mac": "vue-tsc --noEmit && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
    "build:linux": "vue-tsc --noEmit && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.preload.json --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@mimo-ai/cli": "^0.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.2.0",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.12",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vue-tsc": "^3.3.5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.movo.studio",
    "productName": "Movo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "icon": "build/icon.png",
    "asarUnpack": [
      "node_modules/@mimo-ai/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Movo-Setup-Windows.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Movo"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
